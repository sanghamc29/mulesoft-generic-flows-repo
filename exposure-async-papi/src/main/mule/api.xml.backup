	<flow name="api-main-fraud-check" doc:id="0a8246de-02ad-4c30-86b2-31cd6914794d">
        <anypoint-mq:subscriber doc:name="Subscribe to C5 platform events" doc:id="2751578e-4247-48c2-96db-c37677ccc764" config-ref="anypoint-mq-config" destination="${mq.fraudCheckInbound.queue}" acknowledgementMode="MANUAL" acknowledgementTimeout="${mq.fraudCheckInbound.ack.timeout}" acknowledgementTimeoutUnit="SECONDS" primaryNodeOnly="true" circuitBreaker="Circuit_breaker" />
        <tracing:with-correlation-id doc:name="With CorrelationID" doc:id="9e042db2-6421-493a-98cf-05a971cffc45" correlationId="#[message.attributes.properties.correlationId default correlationId]">
            <ee:transform doc:name="Set Variables" doc:id="8432c910-9bcf-494b-aabb-01983b37916f">
                <ee:message />
                <ee:variables>
                    <ee:set-variable variableName="commonLoggingVariable"><![CDATA[%dw 2.0
output application/java
---
"placeholder"]]></ee:set-variable>
                    <ee:set-variable variableName="correlationId"><![CDATA[%dw 2.0
output application/java
---
message.attributes.properties.correlationId default correlationId]]></ee:set-variable>
                    <ee:set-variable variableName="countryCode"><![CDATA[%dw 2.0
output application/java
---
payload.data.payload.EU_Market__c]]></ee:set-variable>
                    <ee:set-variable variableName="applicationFormId"><![CDATA[%dw 2.0
output application/java
---
payload.data.payload.EU_ApplicationFormId__c default ""]]></ee:set-variable>
                    <ee:set-variable variableName="ackToken"><![CDATA[%dw 2.0
output application/json
---
attributes.ackToken]]></ee:set-variable>
                    <ee:set-variable variableName="originalPayload"><![CDATA[%dw 2.0
output application/json
---
payload]]></ee:set-variable>
                    <ee:set-variable variableName="applicantIds" ><![CDATA[%dw 2.0
output application/java
---
(payload.data.payload.EU_Message__c default "") replace  " " with ""]]></ee:set-variable>
                    <ee:set-variable variableName="deliveryCount" ><![CDATA[attributes.deliveryCount]]></ee:set-variable>
                </ee:variables>
            </ee:transform>
            <logger level="INFO" doc:name="Log Request" doc:id="b5dcecf3-97f0-4afe-9219-44bc70de0e74" message="Message received #[vars.commonLoggingVariable]" />
            <logger level="INFO" doc:name="Log Request" doc:id="ffc24220-bab1-4593-b603-d4b7f2917fc5" message="#[output application/java&#10;---&#10;&quot;\'Transaction\': &quot; ++ vars.correlationId default '' ++&#10;&quot;\'CountryCode\': &quot; ++ vars.countryCode default '' ++ &#10;&quot; \'Application Form ID\': &quot; ++ vars.applicationFormId default '' ++&#10;(if(p('log.payloadFlag') == 'true') (&quot;\'Payload\': &quot; ++ write(payload,&quot;application/json&quot;)) else &quot;&quot;)]" />
            <flow-ref doc:name="fraud check orchestration flow" doc:id="09d00501-2971-48e9-83a3-1f6d8a03ccd0" name="c5-fraud-check-orchestration-flow" />
            <anypoint-mq:ack doc:name="Ack" doc:id="df2fa4dd-7da8-4b38-b3ee-aedc8fa15a49" config-ref="anypoint-mq-config" ackToken="#[vars.ackToken]" />
            <logger level="INFO" doc:name="Log Response" doc:id="801b3869-096f-48cf-983b-7b45ece616bf" message="#[output application/java&#10;---&#10;&quot;\'Transaction\': &quot; ++ vars.correlationId ++&#10;&quot;\'CountryCode\': &quot; ++ vars.countryCode ++ &#10;&quot; \'Response HTTP Status\': &quot; ++ (vars.httpStatus default '' ) ++&#10;&quot; \'Application Form ID\': &quot; ++ vars.applicationFormId default '' ++&#10;(if(p('log.payloadFlag') == 'true') (&quot;\'Payload\': &quot; ++ write(payload,&quot;application/json&quot;)) else &quot;&quot;)]" />
            <logger level="INFO" doc:name="Log Response" doc:id="02362891-512e-4f80-a4de-be44bb722f14" message="Message processed successfully#[vars.commonLoggingVariable]" />
        </tracing:with-correlation-id>
        <error-handler ref="mq-global-error-handler" />
    </flow>
