	<flow name="api-main-process-lomapi-agency-reports-callbackflow" doc:id="10d82bf3-1fa2-425a-9795-0fe511fd10bd" >
		<anypoint-mq:subscriber doc:name="Subscribe to C6 (callback) platform events" doc:id="71d5d02c-027d-4403-99c7-ae5ff18dce8b" config-ref="anypoint-mq-config" destination="${mq.lomapiAgencyData.documentsUpload.queue}" acknowledgementMode="MANUAL" acknowledgementTimeout="${mq.lomapiAgencyData.documentsUpload.ack.timeout}" acknowledgementTimeoutUnit="SECONDS" primaryNodeOnly="true" circuitBreaker="Circuit_breaker" />
		<tracing:with-correlation-id doc:name="With CorrelationID" doc:id="aabe62d5-7fa5-41f9-a5d7-378f51d01fe4" correlationId='#[(payload.entities[0].id)++ "-" ++(payload.entities.uniqueId joinBy"") default correlationId]'>
			<ee:transform doc:name="Set Variables" doc:id="e9db38e1-98b3-4b08-b173-93ca16e06a88">
				<ee:message />
				<ee:variables>
					<ee:set-variable variableName="correlationId"><![CDATA[%dw 2.0
output application/java
---
(payload.entities[0].id)++ "-" ++(payload.entities.uniqueId joinBy"") default correlationId]]></ee:set-variable>
					<ee:set-variable variableName="countryCode"><![CDATA[%dw 2.0
output application/java
---
payload.entities.country joinBy"" ]]></ee:set-variable>
					<ee:set-variable variableName="applicationFormId"><![CDATA[%dw 2.0
output application/java
---
payload.entities.applicationFormId joinBy""]]></ee:set-variable>
					<ee:set-variable variableName="ackToken"><![CDATA[%dw 2.0
output application/json
---
attributes.ackToken]]></ee:set-variable>
					<ee:set-variable variableName="originalPayload"><![CDATA[%dw 2.0
output application/json
---
payload]]></ee:set-variable>
					<ee:set-variable variableName="requestEventType" ><![CDATA[%dw 2.0
output application/java
---
payload.eventType]]></ee:set-variable>
					<ee:set-variable variableName="applicantOriginalDocuments" ><![CDATA[%dw 2.0
output application/json
---
read(payload.eventMetadata, "application/json")]]></ee:set-variable>
					<ee:set-variable variableName="commonLoggingVariable"><![CDATA[%dw 2.0
output application/java
---
"placeholder"]]></ee:set-variable>
					<ee:set-variable variableName="applicantId" ><![CDATA[%dw 2.0
output application/java
---
payload.entities[0].id]]></ee:set-variable>
				</ee:variables>
			</ee:transform>
			<logger level="INFO" doc:name="Log Request" doc:id="ede60274-2b77-4e9e-9614-7887ec3c5730" message="#[output application/java&#10;---&#10;&quot;\'Transaction\': &quot; ++ vars.correlationId default '' ++&#10;&quot;\'CountryCode\': &quot; ++ vars.countryCode default '' ++ &#10;&quot; \'Application Form ID\': &quot; ++ vars.applicationFormId default '' ++&#10;(if(p('log.payloadFlag') == 'true') (&quot;\'Payload\': &quot; ++ write(payload,&quot;application/json&quot;)) else &quot;&quot;)]" />
			<logger level="INFO" doc:name="Log Request" doc:id="969fce46-45ad-4886-8616-b816e29e968e" message="Message received#[vars.commonLoggingVariable]" />
			<flow-ref doc:name="process-agency-reports-orchestration-subflow" doc:id="5533889a-452e-4eef-96f0-61266503e3d4" name="process-agency-reports-orchestration-subflow" />
			<anypoint-mq:ack doc:name="Ack" doc:id="77496e7f-c887-4f7d-9306-a44d54c02e4d" config-ref="anypoint-mq-config" ackToken="#[vars.ackToken]" />
			<logger level="INFO" doc:name="Log Response" doc:id="3862c044-62f0-443e-b2aa-0a085c7bf852" message="#[output application/java&#10;---&#10;&quot;\'Transaction\': &quot; ++ vars.correlationId ++&#10;&quot;\'CountryCode\': &quot; ++ vars.countryCode ++ &#10;&quot; \'Response HTTP Status\': &quot; ++ (vars.httpStatus default '' ) ++&#10;&quot; \'Application Form ID\': &quot; ++ vars.applicationFormId default '' ++&#10;(if(p('log.payloadFlag') == 'true') (&quot;\'Payload\': &quot; ++ write(payload,&quot;application/json&quot;)) else &quot;&quot;)]" />
			<logger level="INFO" doc:name="Log Response" doc:id="4d2d263c-9553-450c-b8ec-ddcc1571c245" message="Message processed successfully#[vars.commonLoggingVariable]" />
