	<flow name="api-main-affordability-calculations" doc:id="f4e5fa13-d60b-45b3-b905-ea13d034300d">
		<anypoint-mq:subscriber
			doc:name="Subscribe to C4 platform events"
			doc:id="830601a6-a270-44c7-919b-cda7cf6bc75b"
			destination="${mq.lomapiInbound.queue}"
			config-ref="anypoint-mq-config" acknowledgementMode="MANUAL" acknowledgementTimeoutUnit="SECONDS" acknowledgementTimeout="${mq.lomapiInbound.ack.timeout}" primaryNodeOnly="true" circuitBreaker="Circuit_breaker">
		</anypoint-mq:subscriber>
		<tracing:with-correlation-id doc:name="With CorrelationID" doc:id="cfcb8557-dd5e-48b1-aebb-7cc323c9c7f3" correlationId="#[message.attributes.properties.correlationId default correlationId]">
			<ee:transform doc:name="Set Variables" doc:id="f74be1e2-964e-46cd-bf44-bc1350a61215">
			<ee:message />
			<ee:variables>
      				<ee:set-variable
					resource="dataweaves/v-logging-variable.dwl"
					variableName="commonLoggingVariable" />
				<ee:set-variable variableName="correlationId"><![CDATA[%dw 2.0
output application/java
---
message.attributes.properties.correlationId default correlationId]]></ee:set-variable>
									<ee:set-variable variableName="countryCode"><![CDATA[%dw 2.0
output application/java
---
payload.data.payload.EU_Market__c]]></ee:set-variable>
				<ee:set-variable variableName="applicationFormId"><![CDATA[%dw 2.0
output application/java
---
payload.data.payload.EU_ApplicationFormId__c default ""]]></ee:set-variable>
				<ee:set-variable variableName="ackToken"><![CDATA[%dw 2.0
output application/json
---
attributes.ackToken]]></ee:set-variable>
				<ee:set-variable variableName="originalPayload"><![CDATA[%dw 2.0
output application/json
---
payload]]></ee:set-variable>
				<ee:set-variable variableName="currencyIsoCode"><![CDATA[%dw 2.0
output application/java
---
payload.data.payload.EU_CurrencyIsoCode__c]]></ee:set-variable>
			</ee:variables>
		</ee:transform>
			<logger level="INFO" doc:name="Log Request" doc:id="ce40ef24-f110-451b-8803-951b9bc7f176" message="Message received#[vars.commonLoggingVariable]" />
			<logger level="INFO" doc:name="Log Request" doc:id="6e3460a1-5c12-4900-a9a0-14a317c2a693" message="#[output application/java&#10;---&#10;&quot;\'Transaction\': &quot; ++ vars.correlationId default '' ++&#10;&quot;\'CountryCode\': &quot; ++ vars.countryCode default '' ++ &#10;&quot; \'Application Form ID\': &quot; ++ vars.applicationFormId default '' ++&#10;(if(p('log.payloadFlag') == 'true') (&quot;\'Payload\': &quot; ++ write(payload,&quot;application/json&quot;)) else &quot;&quot;)]" />
			<flow-ref doc:name="affordability-calculations-sub-flow" doc:id="2cecd93f-c16d-434d-9eb5-33482f13ae4e" name="affordability-calculations-sub-flow" />
			<anypoint-mq:ack doc:name="Ack" doc:id="c049f088-8d6a-4a15-8e4b-17a36e5e5e13" config-ref="anypoint-mq-config" ackToken="#[vars.ackToken]" />
			<logger level="INFO" doc:name="Log Response" doc:id="abd1cff6-d924-40c0-9ce6-74a059e1a36c" message="#[output application/java&#10;---&#10;&quot;\'Transaction\': &quot; ++ vars.correlationId ++&#10;&quot;\'CountryCode\': &quot; ++ vars.countryCode ++ &#10;&quot; \'Response HTTP Status\': &quot; ++ (vars.httpStatus default '' ) ++&#10;&quot; \'Application Form ID\': &quot; ++ vars.applicationFormId default '' ++&#10;(if(p('log.payloadFlag') == 'true') (&quot;\'Payload\': &quot; ++ write(payload,&quot;application/json&quot;)) else &quot;&quot;)]" />
			<logger level="INFO" doc:name="Log Response" doc:id="b3c1624f-6bd6-4cab-8106-3a4ceaf33a73" message="Message processed successfully#[vars.commonLoggingVariable]" />
		</tracing:with-correlation-id>
		<error-handler ref="mq-global-error-handler"/>
	</flow>
