	<flow name="api-main-process-lomapi-agency-feedback-flow" doc:id="2e4b6164-e0ef-41c2-accd-019f7655ade4" >
		<anypoint-mq:subscriber doc:name="Subscribe to C7 platform events" doc:id="8243d01a-cd6a-4423-90b1-91d179e61699" config-ref="anypoint-mq-config" destination="${mq.lomapiAgencyFeedback.queue}" acknowledgementMode="MANUAL" acknowledgementTimeout="${mq.lomapiAgencyFeedback.ack.timeout}" acknowledgementTimeoutUnit="SECONDS" primaryNodeOnly="true" circuitBreaker="Circuit_breaker" />
		<tracing:with-correlation-id doc:name="With CorrelationID" doc:id="576a587f-da32-4a51-8d84-7cc9e06234a0" correlationId="#[message.attributes.properties.correlationId default correlationId]" >
			<ee:transform doc:name="set variables" doc:id="0f23a68c-6044-4ba9-af41-c1039a0ede71" >
				<ee:message >
				</ee:message>
				<ee:variables >
					<ee:set-variable variableName="originalPayload" ><![CDATA[%dw 2.0
output application/json
---
payload]]></ee:set-variable>
					<ee:set-variable variableName="commonLoggingVariable" ><![CDATA[%dw 2.0
output application/java
---
" for EventType - " ++ (payload.data.payload.EU_EventType__c default "")  ++ " | ApplicationFormId - " ++ (payload.data.payload.EU_ApplicationFormId__c default "") ++ " | UniqueId - " ++ (payload.data.payload.EU_UniqueId__c default "")]]></ee:set-variable>
					<ee:set-variable variableName="countryCode" ><![CDATA[%dw 2.0
output application/java
---
payload.data.payload.EU_Market__c]]></ee:set-variable>
					<ee:set-variable variableName="correlationId" ><![CDATA[%dw 2.0
output application/java
---
message.attributes.properties.correlationId default correlationId]]></ee:set-variable>
					<ee:set-variable variableName="applicationFormId" ><![CDATA[%dw 2.0
output application/java
---
payload.data.payload.EU_ApplicationFormId__c default ""]]></ee:set-variable>
                   
					<ee:set-variable variableName="ackToken" ><![CDATA[%dw 2.0
output application/json
---
attributes.ackToken]]></ee:set-variable>
					<ee:set-variable variableName="applicantId" ><![CDATA[%dw 2.0
output application/java
---
(payload.data.payload.EU_Message__c replace "[" with "" ) replace "]" with ""]]></ee:set-variable>
					<ee:set-variable variableName="requestEventType" ><![CDATA[%dw 2.0
output application/json
---
payload.data.payload.EU_EventType__c]]></ee:set-variable>
				</ee:variables>
			</ee:transform>
			<logger level="INFO" doc:name="Log Request" doc:id="e5915339-c910-4dd4-bbc2-d9939670017c" message="#[output application/java&#10;---&#10;&quot;\'Transaction\': &quot; ++ vars.correlationId default '' ++&#10;&quot;\'CountryCode\': &quot; ++ vars.countryCode default '' ++ &#10;&quot; \'Application Form ID\': &quot; ++ vars.applicationFormId default '' ++&#10;(if(p('log.payloadFlag') == 'true') (&quot;\'Payload\': &quot; ++ write(payload,&quot;application/json&quot;)) else &quot;&quot;)]" />
			<logger level="INFO" doc:name="Log Request" doc:id="694d468e-dd7c-46f7-9f8a-76082fd23f2a" message="Message received#[vars.commonLoggingVariable]" />
			<flow-ref doc:name="process-lomapi-agency-feedback-subflow" doc:id="0436fc42-4c45-4502-9048-4c23360081e1" name="process-lomapi-agency-feedback-subflow" />
			<anypoint-mq:ack doc:name="Ack" doc:id="dc070b31-cace-4b15-9bdd-fb7971c33476" config-ref="anypoint-mq-config" ackToken="#[vars.ackToken]" />
			<logger level="INFO" doc:name="Log Response" doc:id="a552d825-1fb3-4272-b872-80437ef6d8a4" message="#[output application/java&#10;---&#10;&quot;\'Transaction\': &quot; ++ vars.correlationId ++&#10;&quot;\'CountryCode\': &quot; ++ vars.countryCode ++ &#10;&quot; \'Application Form ID\': &quot; ++ vars.applicationFormId default '' ++&#10;(if(p('log.payloadFlag') == 'true') (&quot;\'Payload\': &quot; ++ write(payload,&quot;application/json&quot;)) else &quot;&quot;)]" />
			<logger level="INFO" doc:name="Log Response" doc:id="c0dacabe-62cc-4a5e-9cab-14263c88d1f4" message="Message processed successfully#[vars.commonLoggingVariable]" />
		</tracing:with-correlation-id>
		<error-handler ref="mq-global-error-handler" />
	</flow>
</mule>
