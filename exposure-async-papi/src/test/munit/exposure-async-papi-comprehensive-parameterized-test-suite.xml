<?xml version="1.0" encoding="UTF-8"?>
<mule xmlns="http://www.mulesoft.org/schema/mule/core" 
      xmlns:doc="http://www.mulesoft.org/schema/mule/documentation" 
      xmlns:munit="http://www.mulesoft.org/schema/mule/munit" 
      xmlns:munit-tools="http://www.mulesoft.org/schema/mule/munit-tools" 
      xmlns:ee="http://www.mulesoft.org/schema/mule/ee/core"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" 
      xsi:schemaLocation="http://www.mulesoft.org/schema/mule/core http://www.mulesoft.org/schema/mule/core/current/mule.xsd 
                          http://www.mulesoft.org/schema/mule/munit http://www.mulesoft.org/schema/mule/munit/current/mule-munit.xsd 
                          http://www.mulesoft.org/schema/mule/munit-tools http://www.mulesoft.org/schema/mule/munit-tools/current/mule-munit-tools.xsd
                          http://www.mulesoft.org/schema/mule/ee/core http://www.mulesoft.org/schema/mule/ee/core/current/mule-ee.xsd">
    
    <munit:config name="exposure-async-papi-comprehensive-parameterized-test-suite.xml">
        <munit:parameterizations file="comprehensive-test-parameters.yaml"/>
    </munit:config>
    
    <!-- =============================================== -->
    <!-- COMPREHENSIVE PARAMETERIZED POSITIVE TESTS -->
    <!-- =============================================== -->
    
    <munit:test name="comprehensive-positive-affordability-calculations-test" 
                description="Parameterized positive test for affordability calculations flow">
        <munit:behavior>
            <set-variable variableName="applicationFormId" value="AFFC-POS-001"/>
            <set-variable variableName="correlationId" value="test-corr-affc-pos-001"/>
            <set-variable variableName="countryCode" value="US"/>
            <set-variable variableName="currencyIsoCode" value="USD"/>

            <!-- Mock SF Accounts SAPI for initial applicant details call -->
            <munit-tools:mock-when processor="http:request">
                <munit-tools:with-attributes>
                    <munit-tools:with-attribute attributeName="config-ref" whereValue="HTTP_Sf_Accounts_Sapi_Request_configuration"/>
                </munit-tools:with-attributes>
                <munit-tools:then-return>
                    <munit-tools:payload value='#[readUrl("classpath://requests/affordabilityCalculationsMultipleApplicants.json", "application/json")]'/>
                    <munit-tools:attributes value='#[{statusCode: 200}]'/>
                </munit-tools:then-return>
            </munit-tools:mock-when>

            <!-- Mock Local Market SAPI for parallel affordability calculations -->
            <munit-tools:mock-when processor="http:request">
                <munit-tools:with-attributes>
                    <munit-tools:with-attribute attributeName="config-ref" whereValue="HTTP_Local_Market_Sapi_Request_configuration"/>
                </munit-tools:with-attributes>
                <munit-tools:then-return>
                    <munit-tools:payload value='{"status":"SUCCESS","affordabilityScore": 750,"payload":{"calculation":"completed","creditScore":750,"approved":true}}'/>
                    <munit-tools:attributes value='#[{statusCode: 200}]'/>
                </munit-tools:then-return>
            </munit-tools:mock-when>

            <!-- Set initial event payload -->
            <munit:set-event>
                <munit:payload value='#[readUrl("classpath://requests/affordabilityCalculationsMultipleApplicants.json", "application/json")]'/>
            </munit:set-event>
        </munit:behavior>

        <munit:execution>
            <flow-ref name="affordability-calculations-sub-flow"/>
        </munit:execution>

        <munit:validation>
            <munit-tools:assert-that expression="#[payload]" is="#[MunitTools::notNullValue()]"/>
            <!-- Verify the parallel processing worked -->
            <munit-tools:assert-that expression="#[sizeOf(payload)]" is="#[MunitTools::greaterThan(0)]"/>
            
            <!-- Verify SF SAPI was called multiple times (initial + final post) -->
            <munit-tools:verify-call processor="http:request" atLeast="2">
                <munit-tools:with-attributes>
                    <munit-tools:with-attribute attributeName="config-ref" whereValue="HTTP_Sf_Accounts_Sapi_Request_configuration"/>
                </munit-tools:with-attributes>
            </munit-tools:verify-call>
            
            <!-- Verify Local Market SAPI was called in parallel foreach -->
            <munit-tools:verify-call processor="http:request" atLeast="2">
                <munit-tools:with-attributes>
                    <munit-tools:with-attribute attributeName="config-ref" whereValue="HTTP_Local_Market_Sapi_Request_configuration"/>
                </munit-tools:with-attributes>
            </munit-tools:verify-call>
        </munit:validation>
    </munit:test>

    <munit:test name="comprehensive-positive-customer-exposure-test" 
                description="Parameterized positive test for customer exposure flow">
        <munit:behavior>
            <set-variable variableName="applicationFormId" value="CEXP-POS-001"/>
            <set-variable variableName="correlationId" value="test-corr-cexp-pos-001"/>
            <set-variable variableName="countryCode" value="US"/>
            <set-variable variableName="currencyIsoCode" value="USD"/>

            <!-- Mock SF Accounts SAPI for applicant details -->
            <munit-tools:mock-when processor="http:request">
                <munit-tools:with-attributes>
                    <munit-tools:with-attribute attributeName="config-ref" whereValue="HTTP_Sf_Accounts_Sapi_Request_configuration"/>
                </munit-tools:with-attributes>
                <munit-tools:then-return>
                    <munit-tools:payload value='#[readUrl("classpath://requests/customerExposureValidCustomers.json", "application/json")]'/>
                    <munit-tools:attributes value='#[{statusCode: 200}]'/>
                </munit-tools:then-return>
            </munit-tools:mock-when>

            <!-- Mock Miles SAPI for parallel exposure calculations -->
            <munit-tools:mock-when processor="http:request">
                <munit-tools:with-attributes>
                    <munit-tools:with-attribute attributeName="config-ref" whereValue="HTTP_Miles_Sapi_Request_configuration"/>
                </munit-tools:with-attributes>
                <munit-tools:then-return>
                    <munit-tools:payload value='{"status":"SUCCESS","exposureCalculated": true,"payload":{"exposureAmount":1000,"currency":"USD"}}'/>
                    <munit-tools:attributes value='#[{statusCode: 200}]'/>
                </munit-tools:then-return>
            </munit-tools:mock-when>

            <munit:set-event>
                <munit:payload value='#[readUrl("classpath://requests/customerExposureValidCustomers.json", "application/json")]'/>
            </munit:set-event>
        </munit:behavior>

        <munit:execution>
            <flow-ref name="customer-exposure-sub-flow"/>
        </munit:execution>

        <munit:validation>
            <munit-tools:assert-that expression="#[payload]" is="#[MunitTools::notNullValue()]"/>
            <!-- Verify filtering worked - only customers with valid customerId should remain -->
            <munit-tools:assert-that expression="#[sizeOf(payload)]" is="#[MunitTools::equalTo(2)]"/>
            
            <!-- Verify SF SAPI was called (initial + final) -->
            <munit-tools:verify-call processor="http:request" atLeast="2">
                <munit-tools:with-attributes>
                    <munit-tools:with-attribute attributeName="config-ref" whereValue="HTTP_Sf_Accounts_Sapi_Request_configuration"/>
                </munit-tools:with-attributes>
            </munit-tools:verify-call>
            
            <!-- Verify Miles SAPI was called for parallel processing -->
            <munit-tools:verify-call processor="http:request" atLeast="2">
                <munit-tools:with-attributes>
                    <munit-tools:with-attribute attributeName="config-ref" whereValue="HTTP_Miles_Sapi_Request_configuration"/>
                </munit-tools:with-attributes>
            </munit-tools:verify-call>
        </munit:validation>
    </munit:test>

    <!-- =============================================== -->
    <!-- COMPREHENSIVE NEGATIVE TESTS -->
    <!-- =============================================== -->
    
    <munit:test name="comprehensive-negative-affordability-calculations-sf-error-test" 
                description="Negative test for affordability calculations when SF SAPI fails">
        <munit:behavior>
            <set-variable variableName="applicationFormId" value="AFFC-NEG-001"/>
            <set-variable variableName="correlationId" value="test-corr-affc-neg-001"/>
            <set-variable variableName="countryCode" value="DE"/>
            <set-variable variableName="currencyIsoCode" value="EUR"/>

            <!-- Mock SF Accounts SAPI to throw error -->
            <munit-tools:mock-when processor="http:request">
                <munit-tools:with-attributes>
                    <munit-tools:with-attribute attributeName="config-ref" whereValue="HTTP_Sf_Accounts_Sapi_Request_configuration"/>
                </munit-tools:with-attributes>
                <munit-tools:then-call flow="sf-sapi-error-mock-flow"/>
            </munit-tools:mock-when>

            <munit:set-event>
                <munit:payload value='[{"externalID1": "NIF001", "applicantId": "APP1", "accountId": "ACC1", "name": "Test User"}]'/>
            </munit:set-event>
        </munit:behavior>

        <munit:execution>
            <try doc:name="Try">
                <flow-ref name="affordability-calculations-sub-flow"/>
                <error-handler>
                    <on-error-continue enableNotifications="true" logException="true" doc:name="On Error Continue">
                        <set-variable value="#[true]" doc:name="Set errorOccurred" variableName="errorOccurred"/>
                        <set-variable value="#[error.errorType.identifier]" doc:name="Set errorType" variableName="errorType"/>
                        <set-payload value='{"error": "SF SAPI call failed", "errorType": "HTTP:BAD_REQUEST"}' doc:name="Set error payload"/>
                    </on-error-continue>
                </error-handler>
            </try>
        </munit:execution>

        <munit:validation>
            <munit-tools:assert-that expression="#[vars.errorOccurred default false]" is="#[MunitTools::equalTo(true)]"/>
            <munit-tools:assert-that expression="#[vars.errorType]" is="#[MunitTools::containsString('HTTP')]"/>
        </munit:validation>
    </munit:test>

