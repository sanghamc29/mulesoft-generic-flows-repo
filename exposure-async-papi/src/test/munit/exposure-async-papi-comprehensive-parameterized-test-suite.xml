    <munit:test name="comprehensive-negative-customer-exposure-no-valid-customers-test" 
                description="Negative test for customer exposure with no valid customers">
        <munit:behavior>
            <set-variable variableName="applicationFormId" value="CEXP-NEG-001"/>
            <set-variable variableName="correlationId" value="test-corr-cexp-neg-001"/>
            <set-variable variableName="countryCode" value="US"/>
            <set-variable variableName="currencyIsoCode" value="USD"/>

            <!-- Mock SF Accounts SAPI -->
            <munit-tools:mock-when processor="http:request">
                <munit-tools:with-attributes>
                    <munit-tools:with-attribute attributeName="config-ref" whereValue="HTTP_Sf_Accounts_Sapi_Request_configuration"/>
                </munit-tools:with-attributes>
                <munit-tools:then-return>
                    <munit-tools:payload value='[
                      {"applicantId": "A1", "accountId": "ACC1", "customerId": null, "name": "John Doe"},
                      {"applicantId": "A2", "accountId": "ACC2", "customerId": null, "name": "Jane Smith"}
                    ]'/>
                    <munit-tools:attributes value='#[{statusCode: 200}]'/>
                </munit-tools:then-return>
            </munit-tools:mock-when>

            <munit:set-event>
                <munit:payload value='[
                  {"applicantId": "A1", "accountId": "ACC1", "customerId": null, "name": "John Doe"},
                  {"applicantId": "A2", "accountId": "ACC2", "customerId": null, "name": "Jane Smith"}
                ]'/>
            </munit:set-event>
        </munit:behavior>

        <munit:execution>
            <flow-ref name="customer-exposure-sub-flow"/>
        </munit:execution>

        <munit:validation>
            <!-- Should return empty array as all customers are filtered out -->
            <munit-tools:assert-that expression="#[payload]" is="#[MunitTools::notNullValue()]"/>
            <munit-tools:assert-that expression="#[sizeOf(payload)]" is="#[MunitTools::equalTo(0)]"/>
            
            <!-- Verify SF SAPI was called but Miles SAPI was not (no valid customers) -->
            <munit-tools:verify-call processor="http:request" atLeast="1">
                <munit-tools:with-attributes>
                    <munit-tools:with-attribute attributeName="config-ref" whereValue="HTTP_Sf_Accounts_Sapi_Request_configuration"/>
                </munit-tools:with-attributes>
            </munit-tools:verify-call>
        </munit:validation>
    </munit:test>

