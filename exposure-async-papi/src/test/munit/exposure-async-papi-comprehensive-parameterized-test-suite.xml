    <munit:test name="comprehensive-negative-fraud-check-partial-failure-test" 
                description="Negative test for C5 fraud check with partial applicant failures">
        <munit:behavior>
            <set-variable variableName="applicationFormId" value="FRAUD-NEG-001"/>
            <set-variable variableName="correlationId" value="test-corr-fraud-neg-001"/>
            <set-variable variableName="countryCode" value="US"/>
            <set-variable variableName="applicantIds" value="A1,A2,A3"/>
            <set-variable variableName="deliveryCount" value="1"/>

            <!-- Mock sub-flows with mixed success/failure results -->
            <munit-tools:mock-when processor="flow-ref">
                <munit-tools:with-attributes>
                    <munit-tools:with-attribute attributeName="name" whereValue="c5-fraud-check-get-applicant-details"/>
                </munit-tools:with-attributes>
                <munit-tools:then-return>
                    <munit-tools:payload value='[{"applicantId":"A1","isSuccessful": true},{"applicantId":"A2","isSuccessful": false},{"applicantId":"A3","isSuccessful": true}]'/>
                    <munit-tools:variables>
                        <munit-tools:variable key="fraudCheckData" value='[{"applicantId":"A1","isSuccessful": true},{"applicantId":"A2","isSuccessful": false},{"applicantId":"A3","isSuccessful": true}]'/>
                    </munit-tools:variables>
                </munit-tools:then-return>
            </munit-tools:mock-when>

            <munit-tools:mock-when processor="flow-ref">
                <munit-tools:with-attributes>
                    <munit-tools:with-attribute attributeName="name" whereValue="c5-fraud-check-lomapi-request-flow"/>
                </munit-tools:with-attributes>
                <munit-tools:then-return>
                    <munit-tools:payload value='[{"applicantId":"A1","status":"SUCCESS"},{"applicantId":"A2","status":"FAILED"},{"applicantId":"A3","status":"SUCCESS"}]'/>
                    <munit-tools:variables>
                        <munit-tools:variable key="fraudCheckData" value='[{"applicantId":"A1","isSuccessful": true},{"applicantId":"A2","isSuccessful": false},{"applicantId":"A3","isSuccessful": true}]'/>
                    </munit-tools:variables>
                </munit-tools:then-return>
            </munit-tools:mock-when>

            <munit-tools:mock-when processor="flow-ref">
                <munit-tools:with-attributes>
                    <munit-tools:with-attribute attributeName="name" whereValue="c5-fraud-check-sf-applicants-flag-update"/>
                </munit-tools:with-attributes>
                <munit-tools:then-return>
                    <munit-tools:payload value='{"status":"PARTIAL_SUCCESS","updated": 2}'/>
                    <munit-tools:variables>
                        <munit-tools:variable key="fraudCheckData" value='[{"applicantId":"A1","isSuccessful": true},{"applicantId":"A2","isSuccessful": false},{"applicantId":"A3","isSuccessful": true}]'/>
                    </munit-tools:variables>
                </munit-tools:then-return>
            </munit-tools:mock-when>

            <munit-tools:mock-when processor="flow-ref">
                <munit-tools:with-attributes>
                    <munit-tools:with-attribute attributeName="name" whereValue="c5-get-sf-documents-for-applicants"/>
                </munit-tools:with-attributes>
                <munit-tools:then-return>
                    <munit-tools:payload value='[{"applicantId":"A1","documentId":"DOC1"},{"applicantId":"A3","documentId":"DOC3"}]'/>
                    <munit-tools:variables>
                        <munit-tools:variable key="fraudCheckData" value='[{"applicantId":"A1","isSuccessful": true},{"applicantId":"A2","isSuccessful": false},{"applicantId":"A3","isSuccessful": true}]'/>
                    </munit-tools:variables>
                </munit-tools:then-return>
            </munit-tools:mock-when>

            <munit-tools:mock-when processor="flow-ref">
                <munit-tools:with-attributes>
                    <munit-tools:with-attribute attributeName="name" whereValue="c5-sf-document-update"/>
                </munit-tools:with-attributes>
                <munit-tools:then-return>
                    <munit-tools:payload value='{"status":"PARTIAL_SUCCESS","documentsUpdated": 2}'/>
                    <munit-tools:variables>
                        <munit-tools:variable key="fraudCheckData" value='[{"applicantId":"A1","isSuccessful": true},{"applicantId":"A2","isSuccessful": false},{"applicantId":"A3","isSuccessful": true}]'/>
                    </munit-tools:variables>
                </munit-tools:then-return>
            </munit-tools:mock-when>

            <!-- Mock error handling flow -->
            <munit-tools:mock-when processor="flow-ref">
                <munit-tools:with-attributes>
                    <munit-tools:with-attribute attributeName="name" whereValue="custom-sf-error-object-ipe"/>
                </munit-tools:with-attributes>
                <munit-tools:then-return>
                    <munit-tools:payload value='{"status":"ERROR_LOGGED","errorId":"ERR-001"}'/>
                </munit-tools:then-return>
            </munit-tools:mock-when>

            <munit:set-event>
                <munit:payload value='[{"applicantId":"A1","type":"individual"},{"applicantId":"A2","type":"business"},{"applicantId":"A3","type":"individual"}]'/>
            </munit:set-event>
        </munit:behavior>

        <munit:execution>
            <flow-ref name="c5-fraud-check-orchestration-flow"/>
        </munit:execution>

        <munit:validation>
            <munit-tools:assert-that expression="#[payload]" is="#[MunitTools::notNullValue()]"/>
            <munit-tools:assert-that expression="#[vars.fraudCheckFailed default false]" is="#[MunitTools::equalTo(true)]"/>
            
            <!-- Verify error handling flow was called -->
            <munit-tools:verify-call processor="flow-ref">
                <munit-tools:with-attributes>
                    <munit-tools:with-attribute attributeName="name" whereValue="custom-sf-error-object-ipe"/>
                </munit-tools:with-attributes>
            </munit-tools:verify-call>
            
            <!-- Verify flag update was called twice (normal + error handling) -->
            <munit-tools:verify-call processor="flow-ref" times="2">
                <munit-tools:with-attributes>
                    <munit-tools:with-attribute attributeName="name" whereValue="c5-fraud-check-sf-applicants-flag-update"/>
                </munit-tools:with-attributes>
            </munit-tools:verify-call>
        </munit:validation>
    </munit:test>

