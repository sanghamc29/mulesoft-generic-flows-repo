            <munit-tools:assert-that expression="#[payload.status]" is="#[MunitTools::equalTo('SUCCESS')]"/>
            <munit-tools:assert-that expression="#[payload.processed]" is="#[MunitTools::equalTo(0)]"/>
            <!-- Verify that applicantsDetails target variable contains empty array -->
            <munit-tools:assert-that expression="#[vars.applicantsDetails]" is="#[MunitTools::notNullValue()]"/>
            <munit-tools:assert-that expression="#[sizeOf(vars.applicantsDetails)]" is="#[MunitTools::equalTo(0)]"/>
        </munit:validation>
    </munit:test>

