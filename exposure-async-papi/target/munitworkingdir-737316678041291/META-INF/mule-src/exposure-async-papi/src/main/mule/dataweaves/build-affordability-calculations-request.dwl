%dw 2.0
output application/json skipNullOn="everywhere"
---
{
    "cashFlow": payload.cashFlow as String default "",
    "cashFlowResult": payload.cashFlowResult as String default "",
    "goodCustomer": payload.goodCustomer as String default "",
    "numberOfArrears": payload.numberOfArrears as Number default 0,
    "paymentBehaviour": payload.paymentBehaviour as String default "",
    "numberOfYearsCustomer": payload.numberOfYearsCustomer as Number default 0,
    "numberOfActiveContracts": payload.numberOfActiveContracts as Number default 0,
    "deniedContracts": payload.deniedContracts as Number default 0,
    "DSTI": payload.DSTI as String default "",
    "deniedContractsDate": payload.deniedContractsDate as String default "",
    "restructuredContracts": payload.restructuredContracts as Number default 0,
    "legacyExposureActive": payload.legacyExposureActive as Number default 0,
    "exposureActiveLegalEntity1": payload.exposureActiveLegalEntity1 as Number default 0,
    "exposureActiveLegalEntity2" : payload.exposureActiveLegalEntity2 as Number default 0,
    "legacyExposureArrears": payload.legacyExposureArrears as Number default 0,
    "exposureArrearsLegalEntity1" : payload.exposureArrearsLegalEntity1 as Number default 0,
    "exposureArrearsLegalEntity2": payload.exposureArrearsLegalEntity2 as Number default 0,
    "legacyExposureInApproval": payload.legacyExposureInApproval as Number default 0,
    "exposureInApprovalLegalEntity1": payload.exposureInApprovalLegalEntity1 as Number default 0,
    "exposureInApprovalLegalEntity2": payload.exposureInApprovalLegalEntity2 as Number default 0,
    "legacyExposureApproved": payload.legacyExposureApproved as Number default 0,
    "exposureApprovedLegalEntity1": payload.exposureApprovedLegalEntity1 as Number default 0,
    "exposureApprovedLegalEntity2": payload.exposureApprovedLegalEntity2 as Number default 0,
    "legacyExposureOutstanding": payload.legacyExposureOutstanding as Number default 0,
    "exposureOutstandingLegalEntity1": payload.exposureOutstandingLegalEntity1 as Number default 0,
    "exposureOutstandingLegalEntity2": payload.exposureOutstandingLegalEntity2 as Number default 0,
    "restructuredContractsArray": (payload.restructuredContractsArray default []) map {
			code: $.code default "",
			date: $.date default ""
    },
    "unpaidInstallmentsFlag": payload.unpaidInstallmentsFlag default false,
    "legalProcessFlag": payload.legalProcessFlag default false,
    "restructuredContractsDate": payload.restructuredContractsDate as String default "",
    "type": "C4 Legacy Data",
    "currencyIsoCode": vars.currencyIsoCode,
    "installmentWithInterestRateAdjustment": payload.installmentWithInterestRateAdjustment as String default "",
    "incomeWithRetirementAdjustment": payload.incomeWithRetirementAdjustment as String default "",
    "monthlyAnnualInstallment": payload.monthlyAnnualInstallment as String default "",
    "provisionsOfAllCustomerCreditAgreements": payload.provisionsOfAllCustomerCreditAgreements as String default "",
    "BalanceSheet": {
        "assets": {
            "balanceSheetDate": payload.BalanceSheet.assets.balanceSheetDate as String default "",
            //"balanceSheetDate": "2023-12",
            "NonCurrentAssets": {
                "propertyPlantAndEquipment": payload.BalanceSheet.assets.NonCurrentAssets.propertyPlantAndEquipment as String default "",
                "investmentProperty": payload.BalanceSheet.assets.NonCurrentAssets.investmentProperty as String default "",
                "goodwill": payload.BalanceSheet.assets.NonCurrentAssets.goodwill as String default "",
                "otherTangibleAssets": payload.BalanceSheet.assets.NonCurrentAssets.otherTangibleAssets as String default "",
                "biologicalAssets": payload.BalanceSheet.assets.NonCurrentAssets.biologicalAssets as String default "",
                "longTermInvestments": payload.BalanceSheet.assets.NonCurrentAssets.longTermInvestments as String default "",
                "longTermInvestmentsOtherMethods": payload.BalanceSheet.assets.NonCurrentAssets.longTermInvestmentsOtherMethods as String default "",
                "shareholders": payload.BalanceSheet.assets.NonCurrentAssets.shareholders as String default "",
                "otherFinancialAssets": payload.BalanceSheet.assets.NonCurrentAssets.otherFinancialAssets as String default "",
                "deferredTaxAssets": payload.BalanceSheet.assets.NonCurrentAssets.deferredTaxAssets as String default "",
                "longTermFinancialAssets": payload.BalanceSheet.assets.NonCurrentAssets.longTermFinancialAssets as String default "",
                "nonCurrentAssetsTotal": payload.BalanceSheet.assets.NonCurrentAssets.nonCurrentAssetsTotal as String default ""
            },
            "CurrentAssets": {
                "inventory": payload.BalanceSheet.assets.CurrentAssets.inventory as String default "",
                "biologicalAssets": payload.BalanceSheet.assets.CurrentAssets.biologicalAssets as String default "",
                "tradeReceivables": payload.BalanceSheet.assets.CurrentAssets.tradeReceivables as String default "",
                "advancedPaymentsToSuppliers": payload.BalanceSheet.assets.CurrentAssets.advancedPaymentsToSuppliers as String default "",
                "stateAndOtherPublicEntities": payload.BalanceSheet.assets.CurrentAssets.stateAndOtherPublicEntities as String default "",
                "shareholders": payload.BalanceSheet.assets.CurrentAssets.shareholders as String default "",
                "otherReceivables": payload.BalanceSheet.assets.CurrentAssets.otherReceivables as String default "",
                "shortTermInvestments": payload.BalanceSheet.assets.CurrentAssets.shortTermInvestments as String default "",
                "prepaidExpenses": payload.BalanceSheet.assets.CurrentAssets.prepaidExpenses as String default "",
                "assetsHeldForTrading": payload.BalanceSheet.assets.CurrentAssets.assetsHeldForTrading as String default "",
                "otherFinancialAssets": payload.BalanceSheet.assets.CurrentAssets.otherFinancialAssets as String default "",
                "nonCurrentAssetsHeldForSale": payload.BalanceSheet.assets.CurrentAssets.nonCurrentAssetsHeldForSale as String default "",
                "otherCurrentAssets": payload.BalanceSheet.assets.CurrentAssets.otherCurrentAssets as String default "",
                "cashAndCashEquivalents": payload.BalanceSheet.assets.CurrentAssets.cashAndCashEquivalents as String default "",
                "currentAssetsTotal": payload.BalanceSheet.assets.CurrentAssets.currentAssetsTotal as String default "",
                "assetsTotal": payload.BalanceSheet.assets.CurrentAssets.assetsTotal as String default ""
            },
            "OwnersEquity": {
                "issuedShares": payload.BalanceSheet.assets.OwnersEquity.issuedShares as String default "",
                "ownShares": payload.BalanceSheet.assets.OwnersEquity.ownShares as String default "",
                "otherShareCapital": payload.BalanceSheet.assets.OwnersEquity.otherShareCapital as String default "",
                "sharePremium": payload.BalanceSheet.assets.OwnersEquity.sharePremium as String default "",
                "corporateLegalReserves": payload.BalanceSheet.assets.OwnersEquity.corporateLegalReserves as String default "",
                "otherReserves": payload.BalanceSheet.assets.OwnersEquity.otherReserves as String default "",
                "retainedEarnings": payload.BalanceSheet.assets.OwnersEquity.retainedEarnings as String default "",
                "adjustmentsInFinancialAssets": payload.BalanceSheet.assets.OwnersEquity.adjustmentsInFinancialAssets as String default "",
                "revaluationReserve": payload.BalanceSheet.assets.OwnersEquity.revaluationReserve as String default "",
                "miscellaneousOtherReserves": payload.BalanceSheet.assets.OwnersEquity.miscellaneousOtherReserves as String default "",
                "netIncome": payload.BalanceSheet.assets.OwnersEquity.netIncome as String default "",
                "dividends": payload.BalanceSheet.assets.OwnersEquity.dividends as String default "",
                "equityTotal": payload.BalanceSheet.assets.OwnersEquity.equityTotal as String default ""
            }
        },
        "liabilities": {
            "NonCurrentLiabilities": {
                "provisions": payload.BalanceSheet.liabilities.NonCurrentLiabilities.provisions as String default "",
                "nonrevolvingLoanLongTerm": payload.BalanceSheet.liabilities.NonCurrentLiabilities.nonrevolvingLoanLongTerm as String default "",
                "postEmploymentBenefits": payload.BalanceSheet.liabilities.NonCurrentLiabilities.postEmploymentBenefits as String default "",
                "deferredTaxLiabilities": payload.BalanceSheet.liabilities.NonCurrentLiabilities.deferredTaxLiabilities as String default "",
                "otherNonFinancialLiabilitiesLongTerm": payload.BalanceSheet.liabilities.NonCurrentLiabilities.otherNonFinancialLiabilitiesLongTerm as String default "",
                "nonCurrentLiabilitiesTotal": payload.BalanceSheet.liabilities.NonCurrentLiabilities.nonCurrentLiabilitiesTotal as String default ""
            },
            "CurrentLiabilities": {
                "tradePayables": payload.BalanceSheet.liabilities.CurrentLiabilities.tradePayables as String default "",
                "advancedPaymentsReceived": payload.BalanceSheet.liabilities.CurrentLiabilities.advancedPaymentsReceived as String default "",
                "stateAndOtherPublicEntities": payload.BalanceSheet.liabilities.CurrentLiabilities.stateAndOtherPublicEntities as String default "",
                "shareholders": payload.BalanceSheet.liabilities.CurrentLiabilities.shareholders as String default "",
                "nonrevolvingLoansShortTerm": payload.BalanceSheet.liabilities.CurrentLiabilities.nonrevolvingLoansShortTerm as String default "",
                "deferredIncome": payload.BalanceSheet.liabilities.CurrentLiabilities.deferredIncome as String default "",
                "financialDebtShortTerm": payload.BalanceSheet.liabilities.CurrentLiabilities.financialDebtShortTerm as String default "",
                "otherFinancialLiabilities": payload.BalanceSheet.liabilities.CurrentLiabilities.otherFinancialLiabilities as String default "",
                "liabilitiesHeldforSale": payload.BalanceSheet.liabilities.CurrentLiabilities.liabilitiesHeldforSale as String default "",
                "liabilitiesHeldForTrading": payload.BalanceSheet.liabilities.CurrentLiabilities.liabilitiesHeldForTrading as String default "",
                "otherCurrentLiabilities": payload.BalanceSheet.liabilities.CurrentLiabilities.otherCurrentLiabilities as String default "",
                "currentLiabilitiesTotal": payload.BalanceSheet.liabilities.CurrentLiabilities.currentLiabilitiesTotal as String default "",
                "liabilitiesTotal": payload.BalanceSheet.liabilities.CurrentLiabilities.liabilitiesTotal as String default "",
                "equityAndLiabilitiesTotal": payload.BalanceSheet.liabilities.CurrentLiabilities.equityAndLiabilitiesTotal as String default ""
            }
        },
        "profitAndLoss": {
            "salesAndServices": payload.BalanceSheet.profitAndLoss.salesAndServices as String default "",
            "revenuesFromGovernmentGrantsOrSubsidies": payload.BalanceSheet.profitAndLoss.revenuesFromGovernmentGrantsOrSubsidies as String default "",
            "profitOrLossesFromSubsidiaries": payload.BalanceSheet.profitAndLoss.profitOrLossesFromSubsidiaries as String default "",
            "changesInInventories": payload.BalanceSheet.profitAndLoss.changesInInventories as String default "",
            "workPerformedAndCapitalized": payload.BalanceSheet.profitAndLoss.workPerformedAndCapitalized as String default "",
            "goodsAndMaterialsConsumed": payload.BalanceSheet.profitAndLoss.goodsAndMaterialsConsumed as String default "",
            "sellingGeneralAdmin": payload.BalanceSheet.profitAndLoss.sellingGeneralAdmin as String default "",
            "wagesAndSalaries": payload.BalanceSheet.profitAndLoss.wagesAndSalaries as String default "",
            "impairmentsOfInventories": payload.BalanceSheet.profitAndLoss.impairmentsOfInventories as String default "",
            "impairmentsOfTradeAndOtherReceivables": payload.BalanceSheet.profitAndLoss.impairmentsOfTradeAndOtherReceivables as String default "",
            "provisions": payload.BalanceSheet.profitAndLoss.provisions as String default "",
            "impairmentsNonDepreciatedInvestments": payload.BalanceSheet.profitAndLoss.impairmentsNonDepreciatedInvestments as String default "",
            "otherImpairments": payload.BalanceSheet.profitAndLoss.otherImpairments as String default "",
            "fairValueIncreaseOrDecrease": payload.BalanceSheet.profitAndLoss.fairValueIncreaseOrDecrease as String default "",
            "otherOperatingIncome": payload.BalanceSheet.profitAndLoss.otherOperatingIncome as String default "",
            "otherOperatingExpenses": payload.BalanceSheet.profitAndLoss.otherOperatingExpenses as String default "",
            "EBITDA": payload.BalanceSheet.profitAndLoss.EBITDA as String default "",
            "depreciationsAndAmortizations": payload.BalanceSheet.profitAndLoss.depreciationsAndAmortizations as String default "",
            "impairmentsDepreciatedInvestments": payload.BalanceSheet.profitAndLoss.impairmentsDepreciatedInvestments as String default "",
            "EBIT": payload.BalanceSheet.profitAndLoss.EBIT as String default "",
            "interestIncome": payload.BalanceSheet.profitAndLoss.interestIncome as String default "",
            "interestExpense": payload.BalanceSheet.profitAndLoss.interestExpense as String default "",
            "EBT": payload.BalanceSheet.profitAndLoss.EBT as String default "",
            "incomeTaxExpense": payload.BalanceSheet.profitAndLoss.incomeTaxExpense as String default "",
            "NI": payload.BalanceSheet.profitAndLoss.NI as String default ""
        }
    }
} ++ vars.salesforceAttributes
