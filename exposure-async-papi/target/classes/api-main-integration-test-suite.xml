    <!-- =============================================== -->
    <!-- NEGATIVE INTEGRATION TESTS -->
    <!-- =============================================== -->
    
    <munit:test name="api-main-affordability-calculations-mq-error-test" description="Negative integration test for affordability calculations with MQ error">
        <munit:behavior>
            <!-- Mock MQ Subscriber to throw error -->
            <munit-tools:mock-when processor="anypoint-mq:subscriber">
                <munit-tools:with-attributes>
                    <munit-tools:with-attribute attributeName="config-ref" whereValue="anypoint-mq-config"/>
                </munit-tools:with-attributes>
                <munit-tools:then-call flow="mq-error-mock-flow"/>
            </munit-tools:mock-when>

            <!-- Mock global error handler -->
            <munit-tools:mock-when processor="error-handler">
                <munit-tools:with-attributes>
                    <munit-tools:with-attribute attributeName="ref" whereValue="mq-global-error-handler"/>
                </munit-tools:with-attributes>
                <munit-tools:then-return>
                    <munit-tools:payload value='{"error":"MQ_ERROR","message":"Message queue error occurred"}'/>
                </munit-tools:then-return>
            </munit-tools:mock-when>

            <munit:set-event>
                <munit:payload value='{"invalid": "payload"}'/>
            </munit:set-event>
        </munit:behavior>

        <munit:execution>
            <try doc:name="Try">
                <flow-ref name="api-main-affordability-calculations"/>
                <error-handler>
                    <on-error-continue enableNotifications="true" logException="true" doc:name="On Error Continue">
                        <set-variable value="#[true]" doc:name="Set mqErrorOccurred" variableName="mqErrorOccurred"/>
                        <set-variable value="#[error.errorType.identifier]" doc:name="Set mqErrorType" variableName="mqErrorType"/>
                        <set-payload value='{"error": "MQ integration failed"}' doc:name="Set MQ error payload"/>
                    </on-error-continue>
                </error-handler>
            </try>
        </munit:execution>

        <munit:validation>
            <munit-tools:assert-that expression="#[vars.mqErrorOccurred default false]" is="#[MunitTools::equalTo(true)]"/>
        </munit:validation>
    </munit:test>

    <!-- =============================================== -->
    <!-- BOUNDARY AND EDGE CASE TESTS -->
    <!-- =============================================== -->
    
    <munit:test name="api-main-boundary-test-large-payload" description="Boundary test for handling large payloads across all flows">
        <munit:behavior>
            <!-- Create large payload with multiple applicants -->
            <ee:transform doc:name="Create Large Test Payload" doc:id="create-large-payload">
                <ee:message>
                    <ee:set-payload><![CDATA[%dw 2.0
output application/json
---
{
  data: {
    payload: {
      EU_Market__c: "US",
      EU_ApplicationFormId__c: "LARGE-APP-001",
      EU_CurrencyIsoCode__c: "USD",
      EU_Message__c: "A1,A2,A3,A4,A5,A6,A7,A8,A9,A10"
    }
  }
}]]></ee:set-payload>
                </ee:message>
            </ee:transform>

            <munit:set-event>
                <munit:payload value='#[payload]'/>
                <munit:attributes value='#[{
                    properties: {correlationId: "test-boundary-large-001"},
                    ackToken: "test-ack-token-boundary-001"
                }]'/>
            </munit:set-event>

            <!-- Mock all sub-flows for large payload processing -->
            <munit-tools:mock-when processor="flow-ref">
                <munit-tools:with-attributes>
                    <munit-tools:with-attribute attributeName="name" whereValue="affordability-calculations-sub-flow"/>
                </munit-tools:with-attributes>
                <munit-tools:then-return>
                    <munit-tools:payload value='{"status":"SUCCESS","recordsProcessed":10,"message":"Large payload processed successfully"}'/>
                    <munit-tools:variables>
                        <munit-tools:variable key="httpStatus" value="200"/>
                    </munit-tools:variables>
                </munit-tools:then-return>
            </munit-tools:mock-when>

            <munit-tools:mock-when processor="anypoint-mq:ack">
                <munit-tools:with-attributes>
                    <munit-tools:with-attribute attributeName="config-ref" whereValue="anypoint-mq-config"/>
                </munit-tools:with-attributes>
                <munit-tools:then-return>
                    <munit-tools:payload value='{"status":"acknowledged"}'/>
                </munit-tools:then-return>
            </munit-tools:mock-when>
        </munit:behavior>

        <munit:execution>
            <flow-ref name="api-main-affordability-calculations"/>
        </munit:execution>

        <munit:validation>
            <munit-tools:assert-that expression="#[payload]" is="#[MunitTools::notNullValue()]"/>
            <munit-tools:assert-that expression="#[payload.recordsProcessed]" is="#[MunitTools::equalTo(10)]"/>
            <munit-tools:assert-that expression="#[vars.correlationId]" is="#[MunitTools::equalTo('test-boundary-large-001')]"/>
        </munit:validation>
    </munit:test>

    <!-- =============================================== -->
    <!-- UTILITY ERROR MOCK FLOWS -->
    <!-- =============================================== -->
    
    <flow name="mq-error-mock-flow" doc:id="mq-error-mock-flow-id">
        <ee:transform doc:name="Set MQ Error Response" doc:id="set-mq-error-response">
            <ee:message>
                <ee:set-payload><![CDATA[%dw 2.0
output application/json
---
{
  "error": "MQ service unavailable",
  "message": "Anypoint MQ subscriber failed to process message",
  "timestamp": now(),
  "errorCode": "MQ_CONNECTION_ERROR"
}]]></ee:set-payload>
            </ee:message>
        </ee:transform>
        <raise-error doc:name="Raise MQ error" doc:id="mq-error-raise" type="ANYPOINT-MQ:CONNECTIVITY"/>
    </flow>

</mule>
