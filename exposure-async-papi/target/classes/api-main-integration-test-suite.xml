    <munit:config name="api-main-integration-test-suite.xml">
        <munit:parameterizations file="test-parameters.yaml"/>
    </munit:config>
    
    <!-- =============================================== -->
    <!-- INTEGRATION TESTS FOR MAIN API FLOWS -->
    <!-- =============================================== -->
    
    <munit:test name="api-main-affordability-calculations-integration-test" description="Integration test for API main affordability calculations flow with MQ subscriber and complete workflow">
        <munit:behavior>
            <!-- Mock MQ Subscriber -->
            <munit-tools:mock-when processor="anypoint-mq:subscriber">
                <munit-tools:with-attributes>
                    <munit-tools:with-attribute attributeName="config-ref" whereValue="anypoint-mq-config"/>
                </munit-tools:with-attributes>
                <munit-tools:then-return>
                    <munit-tools:payload value='#[readUrl("classpath://requests/c4CompanyEvent.json", "application/json")]'/>
                    <munit-tools:attributes value='#[{
                        properties: {correlationId: "test-integration-corr-001"},
                        ackToken: "test-ack-token-001"
                    }]'/>
                </munit-tools:then-return>
            </munit-tools:mock-when>

            <!-- Mock MQ Acknowledgment -->
            <munit-tools:mock-when processor="anypoint-mq:ack">
                <munit-tools:with-attributes>
                    <munit-tools:with-attribute attributeName="config-ref" whereValue="anypoint-mq-config"/>
                </munit-tools:with-attributes>
                <munit-tools:then-return>
                    <munit-tools:payload value='{"status":"acknowledged"}'/>
                </munit-tools:then-return>
            </munit-tools:mock-when>

            <!-- Mock affordability calculations sub-flow -->
            <munit-tools:mock-when processor="flow-ref">
                <munit-tools:with-attributes>
                    <munit-tools:with-attribute attributeName="name" whereValue="affordability-calculations-sub-flow"/>
                </munit-tools:with-attributes>
                <munit-tools:then-return>
                    <munit-tools:payload value='{"status":"SUCCESS","recordsProcessed":2,"message":"Affordability calculations completed successfully"}'/>
                    <munit-tools:variables>
                        <munit-tools:variable key="httpStatus" value="200"/>
                    </munit-tools:variables>
                </munit-tools:then-return>
            </munit-tools:mock-when>

            <!-- Set event with C4 company event structure -->
            <munit:set-event>
                <munit:payload value='#[readUrl("classpath://requests/c4CompanyEvent.json", "application/json")]'/>
                <munit:attributes value='#[{
                    properties: {correlationId: "test-integration-corr-001"},
                    ackToken: "test-ack-token-001"
                }]'/>
            </munit:set-event>
        </munit:behavior>

        <munit:execution>
            <flow-ref name="api-main-affordability-calculations"/>
        </munit:execution>

        <munit:validation>
            <munit-tools:assert-that expression="#[payload]" is="#[MunitTools::notNullValue()]"/>
            <munit-tools:assert-that expression="#[payload.status]" is="#[MunitTools::equalTo('SUCCESS')]"/>
            
            <!-- Verify affordability calculations sub-flow was called -->
            <munit-tools:verify-call processor="flow-ref">
                <munit-tools:with-attributes>
                    <munit-tools:with-attribute attributeName="name" whereValue="affordability-calculations-sub-flow"/>
                </munit-tools:with-attributes>
            </munit-tools:verify-call>
            
            <!-- Verify MQ acknowledgment was called -->
            <munit-tools:verify-call processor="anypoint-mq:ack">
                <munit-tools:with-attributes>
                    <munit-tools:with-attribute attributeName="config-ref" whereValue="anypoint-mq-config"/>
                </munit-tools:with-attributes>
            </munit-tools:verify-call>
            
            <!-- Verify correlation ID was properly set -->
            <munit-tools:assert-that expression="#[vars.correlationId]" is="#[MunitTools::equalTo('test-integration-corr-001')]"/>
        </munit:validation>
    </munit:test>

